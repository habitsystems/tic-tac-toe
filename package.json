{
  "name": "exesandos",
  "version": "1.0.0",
  "description": "A simple Tic-Tac-Toe (Exes and Os) project in TypeScript.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "servor --reload",
    "lint": "eslint . --ext .ts",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "servor": "^4.0.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.0"
  },
  "private": true
}
